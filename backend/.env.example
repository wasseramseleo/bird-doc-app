# BirdDoc backend — local development.
# Copy to .env (auto-loaded by django-environ via settings.py).

DJANGO_SECRET_KEY=django-insecure-dev-only-do-not-use-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Omit DATABASE_URL to use the SQLite default at backend/db.sqlite3.
# DATABASE_URL=postgres://birddoc:birddoc@localhost:5432/birddoc

# CORS/CSRF default to http://localhost:4200 — uncomment to override.
# CORS_ALLOWED_ORIGINS=http://localhost:4200
# CSRF_TRUSTED_ORIGINS=http://localhost:4200

# Email defaults to the console backend in dev (mails print to the log).
# Transactional mail is sent from noreply@birddoc.at — override if needed.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@birddoc.at
# The operator's inbox — receives the in-app "Feedback / Fehler melden" form
# (issue #81) and Warteliste ("Zugang anfragen") access-request leads (issue
# #80), so the operator learns of demand without polling.
# DJANGO_OPERATOR_EMAIL=operator@birddoc.at

# Session cookie is host-only in dev; leave DJANGO_SESSION_COOKIE_DOMAIN unset.

# -----------------------------------------------------------------------------
# Production (app.birddoc.at + apex birddoc.at, see ADR 0007). DO NOT use these
# values in dev. With DJANGO_DEBUG=false the app refuses to boot unless
# DJANGO_SECRET_KEY is a real, non-"django-insecure-" secret — generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
#
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=<a real 50-char random secret — never the dev default>
# DJANGO_ALLOWED_HOSTS=app.birddoc.at,birddoc.at
# CORS_ALLOWED_ORIGINS=https://app.birddoc.at,https://birddoc.at
# CSRF_TRUSTED_ORIGINS=https://app.birddoc.at,https://birddoc.at
# Share the session between the SPA and /admin on the app subdomain:
# DJANGO_SESSION_COOKIE_DOMAIN=app.birddoc.at
# In prod, send over the Brevo (EU) SMTP relay. The SMTP key is a secret —
# supply it via the environment, never commit it.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_DEFAULT_FROM_EMAIL=noreply@birddoc.at
# DJANGO_EMAIL_HOST=smtp-relay.brevo.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=<your Brevo SMTP login>
# DJANGO_EMAIL_HOST_PASSWORD=<your Brevo SMTP key>
# DJANGO_EMAIL_USE_TLS=true
# A real inbox the operator actually monitors for feedback and access requests:
# DJANGO_OPERATOR_EMAIL=<operator inbox, e.g. zugang@birddoc.at>
