# BirdDoc backend — local development.
# Copy to .env (auto-loaded by django-environ via settings.py).

DJANGO_SECRET_KEY=django-insecure-dev-only-do-not-use-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Omit DATABASE_URL to use the SQLite default at backend/db.sqlite3.
# DATABASE_URL=postgres://birddoc:birddoc@localhost:5432/birddoc

# CORS/CSRF default to http://localhost:4200 — uncomment to override.
# CORS_ALLOWED_ORIGINS=http://localhost:4200
# CSRF_TRUSTED_ORIGINS=http://localhost:4200
