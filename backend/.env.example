# Copy to backend/.env for local dev, or render from GitHub secrets in CI/CD.

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (omit DATABASE_URL to fall back to local sqlite at backend/db.sqlite3)
# DATABASE_URL=postgres://birddoc:birddoc@localhost:5432/birddoc

# CORS / CSRF (frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200
