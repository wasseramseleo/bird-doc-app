{
  "name": "bird-doc",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "PLAYWRIGHT_FORCE_ASYNC_LOADER=1 playwright test"
