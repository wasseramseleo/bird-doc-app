# Caddy reverse proxy for the IPAX VPS (ADR 0007 — Cloudflare removed).
#
# Caddy terminates TLS itself via Let's Encrypt (ACME) for every hostname below;
# DNS A records point straight at the VPS public IP. Ports 80 and 443 are
# published on the host (see docker-compose.prod.yml) — 80 carries the ACME
# HTTP-01 challenge plus the automatic HTTP->HTTPS redirect, 443 serves traffic.
{
	# ACME account email — Let's Encrypt sends expiry/again-failure notices here.
	email operator@birddoc.eu
}

# Apex: the public, server-rendered Django landing (marketing + the Zugangscode
# registration, email-verification, password-reset and Org-Einladung accept
# flows). Same gunicorn as the API, routed here by Host (ADR 0009).
birddoc.eu {
	encode gzip

	# Structured JSON access log for server-side AI-visibility measurement
	# (PRD #300, issue #307). Every apex request is recorded as one JSON line;
	# Caddy's JSON access log carries the full request headers by default
	# (credentials redacted), so User-Agent and Referer — the two fields the
	# measurement needs — are always present. The repo script
	# `landing/ai_visibility.py` (`manage.py ai_visibility`) parses this file to
	# aggregate AI answer-fetcher hits (ChatGPT-User/Perplexity-User/Claude-User),
	# general AI-crawler activity and AI referrals. No client-side analytics, no
	# GA4, no consent banner — the public surface stays script-free (ADR 0009).
	#
	# Deploy note (verified manually on deploy — cannot be exercised in CI): the
	# log directory is bind-mounted in docker-compose.prod.yml
	# (`/opt/bird-doc-app/caddy_logs:/var/log/caddy`) so the rolled file persists
	# on the host, where the analysis script reads it.
	log {
		output file /var/log/caddy/birddoc-access.log {
			roll_size 20MiB
			roll_keep 10
		}
		format json
	}

	# Brand assets + the landing's own CSS, collected into the shared volume.
	handle_path /static/* {
		root * /srv/staticfiles
		file_server
	}

	# Landing pages (catchall) -> Django.
	handle {
		reverse_proxy backend:8000
	}
}

# App subdomain: the Angular SPA at /, with the headless API and Django admin.
app.birddoc.eu {
	encode gzip

	# Django backend: API + admin (path NOT stripped).
	handle /api/* {
		reverse_proxy backend:8000
	}
	handle /admin* {
		reverse_proxy backend:8000
	}

	# Static files served directly from the shared volume.
	handle_path /static/* {
		root * /srv/staticfiles
		file_server
	}

	# Angular SPA (catchall).
	handle {
		reverse_proxy frontend:80
	}
}

# birddoc.eu is canonical; the .at hosts 301-redirect to their .eu counterparts,
# preserving path + query ({uri}). `permanent` = HTTP 301.
birddoc.at {
	redir https://birddoc.eu{uri} permanent
}
app.birddoc.at {
	redir https://app.birddoc.eu{uri} permanent
}
